---
import DocumentationCard from "../../components/landing/DocumentationCard.astro";
import SectionHeader from "../../components/landing/SectionHeader.astro";
import CategoryFilterButton from "../../components/shared/CategoryFilterButton.astro";
import NavigationHeader from "../../components/shared/NavigationHeader.astro";
import type { Link } from "../../interfaces/DocsInterfaces";

import DocumentationLayout from "../../layouts/DocumentationLayout.astro";

const documentations: Link[] = [
  {
    title: "SQL Server",
    href: "/documentation/db",
    category: "Base de datos",
    articles: 24,
    description:
      "Convenciones, procedimientos almacenados, índices, transacciones y estándares para SQL Server.",
  },
  {
    title: "Procesos ETL",
    href: "/documentation/etl",
    category: "Integración",
    articles: 12,
    description:
      "Guías para flujos de integración, paquetes SSIS, lookups y manejo de errores.",
  },
];

const categories = [
  "Todas",
  ...new Set(documentations.map((doc) => doc.category)),
];

let currentCategory = "Todas";
---

<DocumentationLayout title="Biblioteca de documentación">
  <NavigationHeader href="/" label="Volver al portal">
    {documentations.length} documentaciones
  </NavigationHeader>

  <!-- Cabecera -->
  <div class="mt-13">
    <SectionHeader
      eyeGreen="documentación"
      title="Biblioteca de "
      description="Explora guías, estándares y recursos técnicos organizados por áreas para facilitar la consulta y mantener un desarrollo consistente."
    />
  </div>

  <!-- Categorías -->
  <div class="mx-auto max-w-5xl">
    <p
      class="mb-4 text-center text-xs font-semibold uppercase tracking-[0.2em] text-emerald-800"
    >
      Categorías
    </p>
  </div>
  <div class="mx-auto flex max-w-5xl flex-wrap justify-center gap-3">
    {
      categories.map((category) => (
        <CategoryFilterButton
          href={`?category=${encodeURIComponent(category ?? "")}`}
          label={category ?? ""}
          active={currentCategory === category}
        />
      ))
    }
  </div>

  <!-- Separador -->
  <div class="mx-auto mt-8 h-px w-full max-w-5xl bg-slate-200/75"></div>

  <!-- Cards -->
  <div class="mx-auto mt-10 grid w-full max-w-5xl gap-6 md:grid-cols-2">
    {
      documentations.map((documentation) => (
        <DocumentationCard
          href={documentation.href}
          title={documentation.title}
          description={documentation.description}
          articles={documentation.articles}
          updated="Recientemente"
        />
      ))
    }
  </div>
</DocumentationLayout>
