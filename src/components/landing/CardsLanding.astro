---
import type { Link } from "../../interfaces/DocsInterfaces";
import DocumentationCard from "./DocumentationCard.astro";

interface Props {
  title?: string;
  description?: string;
  cards: Link[];
}

const {
  title = "Documentaciones disponibles",
  description = "Selecciona el área de conocimiento que deseas consultar.",
  cards,
} = Astro.props;
---

<section class="mx-auto mt-14 w-full max-w-4xl px-5 sm:px-6 lg:px-0">
  <!-- Encabezado -->
  <div class="mb-8 text-center">
    <h2
      class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl"
    >
      {title}
    </h2>

    <p class="mx-auto mt-3 max-w-2xl text-[15px] leading-7 text-slate-600">
      {description}
    </p>
  </div>

  <!-- Grid -->
  <div
    class:list={[
      "grid gap-5",
      cards.length > 2 ? "grid-cols-1 md:grid-cols-2" : "grid-cols-1",
    ]}
  >
    {
      cards.map((card) => (
        <DocumentationCard
          title={card.title}
          href={card.href}
          description={card.description}
        />
      ))
    }
  </div>
</section>
