---
interface Props {
  title: string;
  description?: string;
  align?: "left" | "center";
  eyeGreen?: string;
}

const { title, description = "", align = "center", eyeGreen } = Astro.props;

const alignment =
  align === "left" ? "items-start text-left" : "items-center text-center";

const parts = eyeGreen ? title.split(eyeGreen) : [title];
---

<div class={`mx-auto mb-12 flex w-full max-w-4xl flex-col ${alignment}`}>
  <h2 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
    {
      eyeGreen ? (
        <>
          {parts[0]}
          <span class="text-emerald-700">{eyeGreen}</span>
          {parts[1]}
        </>
      ) : (
        title
      )
    }
  </h2>

  {
    description && (
      <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">
        {description}
      </p>
    )
  }
</div>
