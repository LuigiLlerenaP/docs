---
interface Props {
  titulo?: string;
  textoResaltado?: string;
  descripcion?: string;
  badge?: string;
}

const {
  titulo = "Documentación Técnica",
  textoResaltado = "Desarrollo",
  descripcion = "Estándares de desarrollo y buenas prácticas del equipo de base de datos.",
  badge = "Estándares internos · 2026",
} = Astro.props;
---

<div
  class="mx-auto mt-16 mb-14 flex w-full max-w-4xl flex-col items-center px-6 text-center"
>
  <!-- Badge -->
  <div class="mb-10 flex items-center gap-4">
    <div class="h-px w-8 bg-emerald-600/80"></div>

    <span
      class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500"
    >
      {badge}
    </span>

    <div class="h-px w-8 bg-emerald-600/80"></div>
  </div>

  <!-- Título -->
  <h1
    class="text-5xl font-black leading-[1.03] tracking-tight text-slate-900 md:text-6xl lg:text-7xl"
  >
    {titulo}

    <br />

    <span
      class="bg-linear-to-r from-emerald-700 via-emerald-600 to-emerald-700 bg-clip-text text-transparent"
    >
      {textoResaltado}
    </span>
  </h1>

  <!-- Descripción -->
  <p
    class="mt-12 max-w-3xl text-lg leading-[1.85] tracking-[0.01em] text-slate-500 md:text-[1.22rem]"
  >
    {descripcion}
  </p>
</div>
