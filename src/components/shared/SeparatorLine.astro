---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="flex items-center justify-center gap-5">
  <span class="h-px w-16 bg-linear-to-r from-transparent to-emerald-700"></span>

  <span
    class="text-xs font-semibold uppercase tracking-[0.35em] text-emerald-800"
  >
    {title}
  </span>

  <span class="h-px w-16 bg-linear-to-l from-transparent to-emerald-700"></span>
</div>
