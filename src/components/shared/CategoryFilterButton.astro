---
interface Props {
  href: string;
  label: string;
  active?: boolean;
}

const { href, label, active = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    "group relative px-1 py-2 text-sm transition-colors duration-300 ",
    active
      ? "font-medium text-emerald-700"
      : "text-slate-500 hover:text-slate-800",
  ]}
>
  {label}

  <span
    class:list={[
      "absolute -bottom-0.5 left-0 h-px bg-linear-to-r from-transparent via-emerald-600 to-transparent transition-all duration-300",
      active
        ? "w-full scale-x-100"
        : "w-full scale-x-0 group-hover:scale-x-100",
    ]}></span>
</a>
