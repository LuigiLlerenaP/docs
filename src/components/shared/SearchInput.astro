---
// src/components/SearchInput.astro
---

<div class="relative group w-64">
  <div
    class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none"
  >
    <svg
      class="w-4 h-4 text-slate-400 group-focus-within:text-emerald-800 transition-colors"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
  </div>
  <input
    type="text"
    placeholder="Buscar en SQL Server..."
    class="block w-full rounded-md border border-slate-200 bg-white py-2 pl-10 pr-3 text-sm text-slate-600 placeholder-slate-400 focus:border-emerald-800 focus:outline-none focus:ring-1 focus:ring-emerald-800 transition-all shadow-sm hover:border-slate-300"
  />
</div>
