---
interface Props {
  updated?: string;
}

const { updated } = Astro.props;
---

<div class="mb-10 flex items-center justify-between">
  <a
    href="/documentation"
    class="group inline-flex items-center gap-2 text-sm font-medium text-slate-600 transition-colors duration-300 hover:text-emerald-800 lg:hidden"
  >
    <svg
      class="h-4 w-4 text-emerald-700 transition-transform duration-300 group-hover:-translate-x-0.5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"
      ></path>
    </svg>

    Biblioteca
  </a>

  {
    updated && (
      <span class="ml-auto text-xs font-medium tracking-[0.18em] uppercase text-slate-400">
        {updated}
      </span>
    )
  }
</div>
