---
import LogoLink from "./LogoLink.astro";
import SearchButton from "./SearchButton.astro";
import SidebarNav from "./SidebarNav.astro";
import type { Section } from "../../interfaces/SideBarMenu";

interface Props {
  currentPath: string;
  title: string;
  menuSections: Section[];
}

const { currentPath = "", title, menuSections } = Astro.props as Props;
---

<button
  class="btn-abrir-menu lg:hidden fixed top-4 left-4 z-50
         inline-flex h-11 w-11 items-center justify-center
         rounded-xl border border-slate-200/80
         bg-white/90 backdrop-blur
         shadow-md shadow-slate-900/5
         transition-all duration-200
         hover:-translate-y-0.5
         hover:border-emerald-900/20
         hover:bg-white"
>
  <svg
    class="h-5 w-5 text-slate-700"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>
<aside
  id="mobile-sidebar"
  class="fixed inset-y-0 left-0 z-50
         w-[88vw] max-w-[340px] sm:w-80
         border-r border-slate-200/50 /* ✅ más tenue */
         bg-white/95 backdrop-blur-xl
         flex flex-col
         transform -translate-x-full
         lg:translate-x-0
         transition-transform duration-300 ease-out
         shadow-[4px_0_12px_-6px_rgba(0,0,0,0.08)] /* ✅ sombra lateral suave */
         lg:shadow-none"
>
  <div class="flex items-center px-4 py-3">
    <!-- izquierda (espacio fantasma para centrar) -->
    <div class="w-9 lg:hidden"></div>

    <!-- centro (logo centrado real) -->
    <div class="flex-1 flex justify-center">
      <LogoLink title={title} />
    </div>

    <!-- derecha (botón) -->
    <button
      id="close-sidebar"
      class="lg:hidden inline-flex h-9 w-9 items-center justify-center
           rounded-xl bg-white text-slate-500 shadow-sm
           transition hover:bg-slate-50 hover:text-slate-700"
    >
      ✕
    </button>
  </div>

  <SearchButton placeholder="Buscar en SQL..." />

  <div class="flex-1 overflow-hidden">
    <SidebarNav menuSections={menuSections} currentPath={currentPath} />
  </div>
</aside>

<div
  id="sidebar-overlay"
  class="fixed inset-0 z-40 hidden
         bg-slate-950/30
         backdrop-blur-[2px]
         opacity-0
         transition-opacity duration-300
         lg:hidden"
>
</div>

<script>
  const sidebar = document.getElementById("mobile-sidebar");
  const closeBtn = document.getElementById("close-sidebar");
  const overlay = document.getElementById("sidebar-overlay");
  const openButtons = document.querySelectorAll(".btn-abrir-menu");

  const openSidebar = () => {
    sidebar?.classList.remove("-translate-x-full");

    overlay?.classList.remove("hidden");
    requestAnimationFrame(() => {
      overlay?.classList.remove("opacity-0");
    });
  };

  const closeSidebar = () => {
    sidebar?.classList.add("-translate-x-full");

    overlay?.classList.add("opacity-0");
    setTimeout(() => overlay?.classList.add("hidden"), 300);
  };

  openButtons.forEach((btn) => btn.addEventListener("click", openSidebar));

  closeBtn?.addEventListener("click", closeSidebar);
  overlay?.addEventListener("click", closeSidebar);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeSidebar();
  });
</script>
