---
interface Props {
  href?: string;
  title?: string;
}

const { href = "/", title = "" } = Astro.props as Props;
---

<a
  class="h-15 flex items-center justify-center
         border-b border-slate-100
         px-4 sm:px-5"
  href={href}
>
  <span
    class="text-sm sm:text-base font-semibold tracking-tight text-slate-900"
  >
    <span
      class="w-full
         text-sm sm:text-[15px]
         text-green-800 font-medium tracking-tight
         truncate
         text-center lg:text-left
         transition-colors duration-300 ease-out"
    >
      {title}
    </span>
  </span>
</a>
