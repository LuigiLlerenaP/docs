---
interface Props {
  href?: string;
  title?: string;
}

const { href = "/", title = "" } = Astro.props as Props;
---

<a
  href={href}
  class="group flex h-15 items-center justify-center border-b border-slate-100 px-4 sm:px-5"
>
  <span
    class="relative inline-block text-sm sm:text-[15px] font-medium tracking-tight text-green-800"
  >
    {title}

    <span
      class="absolute -bottom-1 left-1/2 h-px w-0 -translate-x-1/2
             rounded-full
             bg-linear-to-r from-transparent via-green-700/90 to-transparent
             blur-[0.2px]
             transition-all duration-300 ease-out
             group-hover:w-full"
    ></span>
  </span>
</a>
