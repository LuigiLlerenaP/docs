---
// src/components/DocTopBar.astro
const { title } = Astro.props;
---

<header
  class="sticky top-0 z-30 h-16 bg-white/80 backdrop-blur-md border-b border-slate-100 px-8 flex items-center justify-between"
>
  <nav class="flex items-center gap-2 text-sm text-slate-500">
    <a href="/" class="hover:text-emerald-700 text-decoration-none">Portal</a>
    <svg
      class="w-4 h-4 opacity-30"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
    <span class="text-slate-900 font-medium">{title}</span>
  </nav>

  <div class="hidden sm:block">
    <a
      href="#"
      class="text-xs font-medium text-slate-400 hover:text-emerald-800 flex items-center gap-1.5 transition-colors text-decoration-none"
    >
      <svg
        class="w-3.5 h-3.5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M11 4H4a2 2 0 00-2 2v14a2 2 0 00 2 2h14a2 2 0 00 2-2v-7M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"
        ></path>
      </svg>
      Editar página
    </a>
  </div>
</header>
