---
interface Props {
  placeholder?: string;
}

const { placeholder = "Buscar documentación..." } = Astro.props as Props;
---

<div class="px-4 py-4 shrink-0 sm:px-5">
  <button
    type="button"
    class="group flex w-full items-center justify-between rounded-2xl border border-slate-200 bg-white px-3.5 py-3 text-sm shadow-sm transition-all duration-200 hover:border-emerald-900/20 hover:bg-emerald-50/30 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-emerald-900/20"
  >
    <!-- Left content -->
    <div class="flex items-center gap-2.5">
      <svg
        class="h-4 w-4 text-slate-400 transition-colors group-hover:text-emerald-900"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>

      <span class="font-medium text-slate-500 group-hover:text-slate-700">
        {placeholder}
      </span>
    </div>

    <!-- Shortcut (pro UX) -->
    <span
      class="hidden sm:inline-flex items-center rounded-md border border-slate-200 bg-slate-50 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"
    >
      ⌘K
    </span>
  </button>
</div>
